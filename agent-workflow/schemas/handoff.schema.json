{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "handoff",
  "description": "Schema para artefactos de handoff entre agentes. El quality_gate.passed: true es condición para transferir al siguiente agente.",
  "type": "object",
  "required": ["metadata", "handoff_summary", "artifacts", "quality_gate"],
  "properties": {
    "metadata": {
      "type": "object",
      "required": ["artifact_type", "source_agent", "target_agent", "version", "status"],
      "properties": {
        "artifact_type": { "type": "string", "enum": ["agent_handoff"] },
        "source_agent": { "type": "string" },
        "target_agent": { "type": "string" },
        "version": { "type": "string", "pattern": "^\\d+\\.\\d+$" },
        "status": {
          "type": "string",
          "enum": ["draft", "in_review", "ready_for_next_agent", "rejected", "archived"]
        },
        "created_at": { "type": "string", "format": "date" },
        "requires_human_review": { "type": "boolean" }
      }
    },
    "handoff_summary": {
      "type": "object",
      "required": ["completed_work"],
      "properties": {
        "business_context": { "type": "string" },
        "technical_context": { "type": "string" },
        "crisp_dm_phase": { "type": "string" },
        "completed_work": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "pending_work": { "type": "array", "items": { "type": "string" } },
        "key_decisions": { "type": "array", "items": { "type": "string" } },
        "known_limitations": { "type": "array", "items": { "type": "string" } }
      }
    },
    "artifacts": {
      "type": "object",
      "required": ["inputs_used", "outputs_generated", "required_next_inputs"],
      "properties": {
        "inputs_used": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "outputs_generated": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "evidence": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "type": { "type": "string", "enum": ["commit", "pr", "issue", "file", "screenshot", "log", "other"] },
              "reference": { "type": "string" },
              "description": { "type": "string" }
            }
          }
        },
        "required_next_inputs": { "type": "array", "items": { "type": "string" }, "minItems": 1 }
      }
    },
    "quality_gate": {
      "type": "object",
      "required": ["passed", "checks"],
      "properties": {
        "passed": { "type": "boolean" },
        "checks": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "result"],
            "properties": {
              "name": { "type": "string" },
              "result": { "type": "string", "enum": ["pass", "fail", "warn", "skip", "pending"] },
              "notes": { "type": "string" }
            }
          }
        },
        "issues": { "type": "array", "items": { "type": "string" } },
        "required_approvals": { "type": "array", "items": { "type": "string" } }
      }
    },
    "open_questions": { "type": "array", "items": { "type": "object" } },
    "assumptions": { "type": "array", "items": { "type": "object" } },
    "risks": { "type": "array", "items": { "type": "object" } },
    "blockers": { "type": "array", "items": { "type": "string" } },
    "recommendation_to_next_agent": { "type": "string" }
  }
}
